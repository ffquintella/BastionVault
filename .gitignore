# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk
*~
*.bak

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb


# Added by cargo

/target

# Isolated target dir for the `bv-plugin-pack` packer/signer, kept out
# of the shared ./target so plugin builds don't invalidate the GUI's
# cache (see PLUGINS_PACK_TARGET_DIR in the Makefile).
/target-plugin-pack

# VIM temp file
*.swp

# Claude Code local settings (machine-local)
.claude/
.DS_Store

# Local container-image push config (operator-specific; written by
# `make container-repo-setup`, consumed by `make container-image-push`).
.container-repo.env
