<?xml version="1.0" encoding="utf-8"?>
<!--
  productbuild distribution definition for the BastionVault GUI .pkg.
  build-gui-pkg.sh substitutes @VERSION@ and @HOSTARCH@ before handing
  this to productbuild. The component package it wraps installs
  BastionVault.app into /Applications.
-->
<installer-gui-script minSpecVersion="2">
    <title>BastionVault</title>
    <organization>io.bastionvault</organization>
    <options customize="never" require-scripts="false" hostArchitectures="@HOSTARCH@"/>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.bastionvault.gui"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.bastionvault.gui" visible="false">
        <pkg-ref id="com.bastionvault.gui"/>
    </choice>
    <pkg-ref id="com.bastionvault.gui" version="@VERSION@" onConclusion="none">component.pkg</pkg-ref>
</installer-gui-script>
