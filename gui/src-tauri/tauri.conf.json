{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-docs/refs/heads/v2/tooling/cli/schema.json",
  "productName": "BastionVault",
  "version": "0.28.14",
  "identifier": "com.bastionvault.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BastionVault",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "BastionVault Contributors",
    "homepage": "https://github.com/ffquintella/BastionVault",
    "category": "Utility",
    "shortDescription": "BastionVault desktop client",
    "longDescription": "BastionVault desktop GUI — an identity-based secrets manager with a HashiCorp Vault-compatible API, post-quantum cryptography, and an embedded local-vault mode.",
    "licenseFile": "../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "utils",
        "priority": "optional",
        "postInstallScript": "installers/linux/postinst",
        "preRemoveScript": "installers/linux/prerm"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"],
        "postInstallScript": "installers/linux/postinst",
        "preRemoveScript": "installers/linux/prerm"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
