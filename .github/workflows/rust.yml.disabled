name: Vulnerability Audit

# Replaces the previous test / lint / coverage matrix with a single
# focused job: run `cargo audit` against the workspace's resolved
# dependency tree on every push. Tests and clippy belong on the
# developer's machine — this CI surface only exists to catch
# RustSec advisories before they ship.
#
# We deliberately do NOT run on pull_request: PRs from forks can't
# read repo secrets, and the advisory DB is public anyway, so push-
# only is the right scope. PRs from this repo merge to a branch that
# then triggers this workflow.

# TEMPORARILY DISABLED: cargo-audit currently fails to resolve the
# workspace because vanilla `russh 0.60.3` and `sspi 0.20.x/0.21.x`
# pin incompatible RustCrypto pre-release versions
# (`ed25519-dalek`, `p256`, `ml-kem`). Until upstream Devolutions
# bumps picky/sspi to the pre.7 RustCrypto slice (tracked by the
# monthly "Check if russh/sspi patch can be reverted" routine at
# https://claude.ai/code/routines), the audit job cannot generate a
# lockfile to scan and would fail every push. Re-enable by switching
# `on: workflow_dispatch` back to `on: push` once that routine
# reports READY TO REVERT.
on:
  workflow_dispatch:

env:
  CARGO_TERM_COLOR: always

jobs:
  cargo-audit:
    name: cargo audit
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      # Cargo.lock is gitignored in this repo, so cargo-audit has
      # nothing to scan until we materialise one. `generate-lockfile`
      # picks the same minimum-acceptable versions Cargo would on a
      # fresh checkout — exactly what we want to scan.
      - name: Generate Cargo.lock
        run: cargo generate-lockfile

      - name: Install cargo-audit
        run: cargo install --locked cargo-audit

      # `--deny warnings` turns unmaintained crate notices into hard
      # failures alongside actual vulnerabilities, so we hear about
      # them before the next 0-day lands on a stale dep.
      - name: Run cargo audit
        run: cargo audit --deny warnings
